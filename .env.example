# Docker Compose / production deployment
FRONTEND_PORT=3000

DATABASE_URL=sqlite:////app/data/restaurant.db
SECRET_KEY=change-this-secret-key-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@example.com

# Укажите свой реальный домен перед production-деплоем
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Для демонстрационного проекта оставьте true, чтобы автоматически
# заполнить пустую БД стартовыми данными.
INIT_SAMPLE_DATA=true
